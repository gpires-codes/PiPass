{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "PiPass",
  "version": "0.1.0",
  "identifier": "com.gapires.pipass",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:3012",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "PiPass",
        "width": 500,
        "height": 400,
        "decorations": false,
        "resizable": true,
        "fullscreen": false,
        "alwaysOnTop": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
